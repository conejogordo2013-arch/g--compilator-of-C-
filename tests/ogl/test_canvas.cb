import system;

struct OglCanvas {
    int32 width;
    int32 height;
    int32 state;
    int32 alive;
};

extern int32 ogl_canvas_create(struct OglCanvas*, int32, int32);
extern void ogl_canvas_destroy(struct OglCanvas*);
extern void ogl_canvas_clear(struct OglCanvas*, int32);
extern void ogl_canvas_fill_rect(struct OglCanvas*, int32, int32, int32, int32, int32);
extern void ogl_canvas_draw_line(struct OglCanvas*, int32, int32, int32, int32, int32);
extern int32 ogl_canvas_set_pixel(struct OglCanvas*, int32, int32, int32);
extern int32 ogl_canvas_checksum(struct OglCanvas*);
extern int32 ogl_color_black();
extern int32 ogl_color_white();
extern int32 ogl_color_red();

int32 main() {
    struct OglCanvas c;
    if (ogl_canvas_create(&c, 16, 16) == 0) {
        system_exit(1);
        return 0;
    }

    ogl_canvas_clear(&c, ogl_color_black());
    ogl_canvas_fill_rect(&c, 1, 1, 5, 4, ogl_color_red());
    ogl_canvas_draw_line(&c, 0, 15, 15, 0, ogl_color_white());

    if (ogl_canvas_set_pixel(&c, -1, 0, ogl_color_white()) != 0) {
        ogl_canvas_destroy(&c);
        system_exit(2);
        return 0;
    }

    int32 sig = ogl_canvas_checksum(&c) % 251;
    ogl_canvas_destroy(&c);

    if (sig != 0) {
        system_exit(sig);
        return 0;
    }

    system_exit(0);
    return 0;
}
