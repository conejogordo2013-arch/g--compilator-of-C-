import system;

int32 simulate(int32 steps) {
    int32 state = 3;
    int32 acc = 0;
    int32 i = 0;

    while (i < steps) {
        if ((i % 2) == 0) state = ((state * 5) + 1) % 17;
        else state = ((state * 7) + 3) % 17;

        if ((i % 3) == 0) acc = acc + (state * 2);
        else acc = acc + (state - 1);

        i = i + 1;
    }

    return acc % 101;
}

int32 main() {
    system_exit(simulate(75));
    return 0;
}
