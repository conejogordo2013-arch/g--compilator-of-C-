import system;

extern void cbabi_runtime_init();
extern int32 cbabi_version_major();
extern int32 cbabi_callconv_probe6(int32, int32, int32, int32, int32, int32);
extern int64 alloc(int64);
extern void free(int64);

extern int32 cbabi_program_a_make(int64);
extern int32 cbabi_program_a_get_kind(int64);
extern int32 cbabi_program_a_get_flags(int64);
extern int64 cbabi_program_a_get_payload(int64);
extern int64 cbabi_program_a_payload_plus(int64, int64);

int32 main() {
    cbabi_runtime_init();

    if (cbabi_version_major() != 1) {
        system_exit(1);
        return 1;
    }

    int64 h = alloc(24);
    if (h == 0) {
        system_exit(8);
        return 8;
    }

    if (cbabi_program_a_make(h) != 10) {
        system_exit(2);
        return 2;
    }

    if (cbabi_program_a_payload_plus(h, 24) != 1024) {
        system_exit(6);
        return 6;
    }

    if (cbabi_callconv_probe6(1, 2, 3, 4, 5, 6) != 91) {
        system_exit(7);
        return 7;
    }

    free(h);
    system_exit(0);
    return 0;
}
