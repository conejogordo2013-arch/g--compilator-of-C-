// Módulo A: compilado por separado (simula otra unidad/binario).

int32 cbabi_program_a_make(int64 p) {
    int64* raw = p;
    *(raw + 0) = 7;
    *(raw + 1) = 3;
    *(raw + 2) = 1000;
    return 10;
}

int32 cbabi_program_a_get_kind(int64 p) {
    int64* raw = p;
    return *(raw + 0);
}

int32 cbabi_program_a_get_flags(int64 p) {
    int64* raw = p;
    return *(raw + 1);
}

int64 cbabi_program_a_get_payload(int64 p) {
    int64* raw = p;
    return *(raw + 2);
}

int64 cbabi_program_a_payload_plus(int64 p, int64 delta) {
    int64* raw = p;
    return *(raw + 2) + delta;
}
