import system;

extern int64 cb_alloc_bytes(int64);
extern void cb_free_ptr(int64);
extern void cb_mem_set_i64(int64*, int32, int64);

int32 main() {
    int64 raw = cb_alloc_bytes(8);
    if (raw == 0) { system_exit(1); return 1; }
    int64* p = raw;
    cb_mem_set_i64(p, 1, 9);
    if (*(p + 0) != 9) { cb_free_ptr(raw); system_exit(2); return 2; }
    cb_free_ptr(raw);
    system_exit(0);
    return 0;
}
