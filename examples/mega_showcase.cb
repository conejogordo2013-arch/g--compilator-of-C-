int32 run_all(int32 seed) {
    int32 acc = seed;
    acc = arith_01(acc);
    acc = arith_02(acc);
    acc = arith_03(acc);
    acc = arith_04(acc);
    acc = arith_05(acc);
    acc = arith_06(acc);
    acc = arith_07(acc);
    acc = arith_08(acc);
    acc = arith_09(acc);
    acc = arith_10(acc);
    acc = arith_11(acc);
    acc = arith_12(acc);
    acc = arith_13(acc);
    acc = arith_14(acc);
    acc = arith_15(acc);
    acc = arith_16(acc);
    acc = arith_17(acc);
    acc = arith_18(acc);
    acc = arith_19(acc);
    acc = arith_20(acc);
    acc = bitwise_01(acc);
    acc = bitwise_02(acc);
    acc = bitwise_03(acc);
    acc = bitwise_04(acc);
    acc = bitwise_05(acc);
    acc = bitwise_06(acc);
    acc = bitwise_07(acc);
    acc = bitwise_08(acc);
    acc = bitwise_09(acc);
    acc = bitwise_10(acc);
    acc = bitwise_11(acc);
    acc = bitwise_12(acc);
    acc = bitwise_13(acc);
    acc = bitwise_14(acc);
    acc = bitwise_15(acc);
    acc = bitwise_16(acc);
    acc = bitwise_17(acc);
    acc = bitwise_18(acc);
    acc = bitwise_19(acc);
    acc = bitwise_20(acc);
    acc = branch_01(acc);
    acc = branch_02(acc);
    acc = branch_03(acc);
    acc = branch_04(acc);
    acc = branch_05(acc);
    acc = branch_06(acc);
    acc = branch_07(acc);
    acc = branch_08(acc);
    acc = branch_09(acc);
    acc = branch_10(acc);
    acc = branch_11(acc);
    acc = branch_12(acc);
    acc = branch_13(acc);
    acc = branch_14(acc);
    acc = branch_15(acc);
    acc = loop_01(acc);
    acc = loop_02(acc);
    acc = loop_03(acc);
    acc = loop_04(acc);
    acc = loop_05(acc);
    acc = loop_06(acc);
    acc = loop_07(acc);
    acc = loop_08(acc);
    acc = loop_09(acc);
    acc = loop_10(acc);
    acc = loop_11(acc);
    acc = loop_12(acc);
    return acc;
}

int32 main() {
    struct Metrics m;
    struct Pair p;
    p.a = 7;
    p.b = 11;
    metrics_init(&m, 19);

    int32 i = 0;
    int32 acc = 19;
    while (i < 12) {
        acc = run_all((acc + i + rec_sum(i % 5)) % 251);
        acc = (acc + rec_mix((i % 6) + 2)) % 251;
        acc = (acc + struct_fn_01(&p, acc)) % 251;
        acc = (acc + struct_fn_02(&p, acc)) % 251;
        acc = (acc + struct_fn_03(&p, acc)) % 251;
        acc = (acc + struct_fn_04(&p, acc)) % 251;
        acc = (acc + struct_fn_05(&p, acc)) % 251;
        acc = (acc + struct_fn_06(&p, acc)) % 251;
        acc = (acc + struct_fn_07(&p, acc)) % 251;
        acc = (acc + struct_fn_08(&p, acc)) % 251;
        metrics_push(&m, acc);
        i = i + 1;
    }

    int32 signature = (m.minv + (m.maxv * 2) + m.sum + m.count + p.a + p.b + acc + abs_i32(acc - 100)) % 127;
    system_exit(signature);
    return 0;
}
