int32 struct_fn_01(struct Pair* p, int32 x) {
    p->a = (p->a + x + 3) % 251;
    p->b = (p->b + p->a + 1) % 251;
    int32 z = pair_fold(p, (x % 7) + 1);
    return z % 251;
}

int32 struct_fn_02(struct Pair* p, int32 x) {
    p->a = (p->a + x + 5) % 251;
    p->b = (p->b + p->a + 2) % 251;
    int32 z = pair_fold(p, (x % 7) + 1);
    return z % 251;
}

int32 struct_fn_03(struct Pair* p, int32 x) {
