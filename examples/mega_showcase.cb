int32 branch_01(int32 x) {
    if ((x % 5) == 0) {
        return (x / 5 + 7) % 251;
    } else if ((x & 1) == 0) {
        return (x + 5 + 7) % 251;
    }
    return (x * 5 + 7) % 251;
}

