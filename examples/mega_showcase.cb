import system;

// mega_showcase.cb: demostración extensa de sintaxis C! con funciones de varios tipos.
// Incluye: aritmética, bitwise, ramas, loops, punteros/structs y recursión controlada.

struct Pair {
    int32 a;
    int32 b;
};

struct Metrics {
    int32 minv;
    int32 maxv;
    int32 sum;
    int32 count;
};

int32 abs_i32(int32 v) {
    if (v < 0) return -v;
    return v;
}

void metrics_init(struct Metrics* m, int32 seed) {
    m->minv = seed;
    m->maxv = seed;
    m->sum = seed;
    m->count = 1;
}

void metrics_push(struct Metrics* m, int32 v) {
    if (v < m->minv) m->minv = v;
    if (v > m->maxv) m->maxv = v;
    m->sum = (m->sum + v) % 100000;
    m->count = m->count + 1;
}

int32 pair_fold(struct Pair* p, int32 k) {
    int32 x = (p->a * k) + (p->b * (k + 1));
    return x % 997;
}

int32 rec_sum(int32 n) {
    if (n <= 0) return 0;
    return n + rec_sum(n - 1);
}

int32 rec_mix(int32 n) {
    if (n <= 1) return 1;
    return (rec_mix(n - 1) + rec_mix(n - 2) + n) % 97;
}

int32 arith_01(int32 x) {
    int32 y = (x + 8) % 1009;
    y = (y * 9) % 1009;
    y = y - 12;
    if (y < 0) y = y + 1009;
    return y % 251;
}

