// kernel.cb - basic C! kernel entry used by the stage0 compiler.

int32 kernel_uptime_ticks(int32 seed) {
    int32 ticks = seed;
    int32 i = 0;

    while (i < 8) {
        ticks = ticks + 1;
        i = i + 1;
    }

    return ticks;
}

int32 kmain() {
    int32 ticks = kernel_uptime_ticks(0);

    if (ticks == 8) {
        return 0;
    }

    return 1;
}
